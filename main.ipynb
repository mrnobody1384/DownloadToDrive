# ======================================================
# ۱. نصب کتابخانه‌های مورد نیاز و احراز هویت
# ======================================================
from google.colab import auth
auth.authenticate_user()

from googleapiclient.discovery import build
from googleapiclient.http import MediaFileUpload
import requests
import os
from tqdm.notebook import tqdm
import time

drive_service = build('drive', 'v3')

# ======================================================
# ۲. دریافت اطلاعات از کاربر
# ======================================================
file_url = input("🔗 لینک فایل را وارد کنید: ")
file_name = input("📄 نام فایل نهایی در Google Drive (با پسوند): ")

# ======================================================
# ۳. دانلود فایل به صورت موقت در Colab
# ======================================================
temp_path = f"/tmp/{file_name}"
print(f"\n⏬ در حال دانلود {file_name} ...")
response = requests.get(file_url, stream=True)
total_size = int(response.headers.get('content-length', 0))

with open(temp_path, 'wb') as f, tqdm(
    total=total_size, unit='iB', unit_scale=True, desc=file_name
) as pbar:
    for chunk in response.iter_content(chunk_size=1024*1024):  # 1 مگابایت
        if chunk:
            f.write(chunk)
            pbar.update(len(chunk))

print("✅ دانلود کامل شد.")

# ======================================================
# ۴. آپلود فایل در Google Drive با نوار پیشرفت
# ======================================================
file_metadata = {'name': file_name}
media = MediaFileUpload(temp_path, resumable=True)

# آپلود به صورت تکه‌ای با نمایش درصد
print("⏫ در حال آپلود در Google Drive ...")
request = drive_service.files().create(body=file_metadata, media_body=media, fields='id')

# نمایش نوار پیشرفت در آپلود (با کلاس سفارشی)
class UploadProgress(tqdm):
    def __init__(self, total_size, desc):
        super().__init__(total=total_size, unit='iB', unit_scale=True, desc=desc)

    def next_chunk(self, request):
        response = None
        self.__bytes_so_far = 0
        while response is None:
            status, response = request.next_chunk()
            if status:
                self.update(status.resumable_progress - self.__bytes_so_far)
                self.__bytes_so_far = status.resumable_progress
        return response

total_file_size = os.path.getsize(temp_path)
progress_bar = UploadProgress(total_file_size, desc=f"آپلود {file_name}")

# شروع آپلود با نمایش نوار پیشرفت
file = progress_bar.next_chunk(request)
file_id = file.get('id')
print(f"\n✅ فایل با موفقیت آپلود شد.\n🆔 File ID: {file_id}")

# ======================================================
# ۵. عمومی کردن فایل (Anyone with the link)
# ======================================================
permission = {
    'type': 'anyone',
    'role': 'reader'
}
drive_service.permissions().create(fileId=file_id, body=permission).execute()
print("🔓 دسترسی عمومی تنظیم شد.")

# ======================================================
# ۶. ساخت لینک مستقیم دانلود
# ======================================================
direct_link = f"https://drive.google.com/uc?export=download&id={file_id}"
print("\n" + "="*55)
print("🔗 لینک مستقیم دانلود (برای اشتراک با دیگران):")
print(direct_link)
print("="*55)

# ======================================================
# ۷. پاکسازی فایل موقت (اختیاری)
# ======================================================
os.remove(temp_path)
print("🧹 فایل موقت پاک شد.")
